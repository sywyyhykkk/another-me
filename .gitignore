cloudfunctions/*/shared/

# 使用 uni_modules/uni-icons 时仍保留 package.json 供 HBuilderX「npm 安装」

# 编译产物
unpackage/
dist/

# HBuilderX
.hbuilderx/

# 微信开发者工具个人配置（含本地路径等）
project.private.config.json

# 环境变量（含密钥，勿提交）
.env
.env.local
.env.*.local

# 日志
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 系统文件
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
